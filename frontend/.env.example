# Trustee Platform frontend — runtime config (NEXT_PUBLIC_* is exposed to the browser).
# Copy to .env.local and adjust. These are NOT secrets (public Cognito IDs + API URL).

# FastAPI backend base URL (no trailing slash).
NEXT_PUBLIC_API_BASE=https://your-api-id.execute-api.af-south-1.amazonaws.com

# Cognito user pool (af-south-1 dev). Public identifiers, safe to ship to the browser.
NEXT_PUBLIC_COGNITO_REGION=af-south-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=af-south-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-app-client-id
